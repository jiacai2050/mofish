<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>每日精选 Hacker News 热帖，AI 摘要助你高效阅读</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
  <link rel="stylesheet" href="style.css">
  <link rel="alternate" type="application/atom+xml" title="每日精选 Hacker News 热帖" href="feed.xml">
</head>
<body>
  <main class="container">
    <p>每日精选 Hacker News 热帖，AI 总结助你高效阅读。 <a href="feed.xml">RSS</a> | <a href="https://github.com/jiacai2050/mofish">GitHub</a></p>
    <% months.forEach(function(month) { %>
    <section class="month-section">
      <h2><%= month.label %></h2>
      <ul class="day-list">
        <% month.days.forEach(function(day) { %>
        <li>
          <% if (day.count > 0) { %>
          <a href="<%= day.date %>.html"><span class="day-date"><%= day.date %></span><span class="day-top1"><%= day.top1 %></span></a>
          <% } else { %>
          <a href="https://news.ycombinator.com/front?day=<%= day.date %>" target="_blank" rel="noopener"><span class="day-date"><%= day.date %></span><span class="day-top1">-</span></a>
          <% } %>
        </li>
        <% }); %>
      </ul>
    </section>
    <% }); %>
    <footer>
      <p><small>数据来源: <a href="https://news.ycombinator.com">Hacker News</a> | <a href="https://github.com/jiacai2050/mofish">GitHub</a> | <a href="feed.xml">Feed</a></small></p>
    </footer>
  </main>
</body>
</html>
